{
  "name": "clear-path",
  "version": "1.14.0",
  "author": "Jason Humphrey",
  "description": "ClearPathAI — Desktop control tower for AI coding agents",
  "main": "out/main/index.js",
  "scripts": {
    "generate:flags": "node scripts/generate-feature-flags.mjs",
    "predev": "node scripts/generate-feature-flags.mjs",
    "prebuild": "node scripts/generate-feature-flags.mjs",
    "pretest": "node scripts/generate-feature-flags.mjs",
    "dev": "electron-vite dev",
    "dev:preview": "CLEARPATH_FLAGS_LOCKED=1 electron-vite dev",
    "dev:experimental": "CLEARPATH_E2E_EXPERIMENTAL=1 electron-vite dev",
    "build": "electron-vite build",
    "build:locked": "CLEARPATH_FLAGS_LOCKED=1 electron-vite build",
    "build:experimental": "CLEARPATH_E2E_EXPERIMENTAL=1 electron-vite build",
    "preview": "electron-vite preview",
    "preview:locked": "npm run build:locked && electron-vite preview",
    "preview:experimental": "npm run build:experimental && electron-vite preview",
    "package": "npm run build && electron-builder",
    "package:mac": "npm run build && electron-builder --mac",
    "package:linux": "npm run build && electron-builder --linux",
    "package:win": "npm run build && electron-builder --win",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "package:extension": "node extension-sdk/scripts/package-extension.js",
    "package:extensions": "node extension-sdk/scripts/package-extension.js extensions/com.clearpathai.backstage-explorer --output dist-extensions/ && node extension-sdk/scripts/package-extension.js extensions/com.clearpathai.efficiency-coach --output dist-extensions/ && node extension-sdk/scripts/package-extension.js extensions/com.clearpathai.pr-scores --output dist-extensions/",
    "pretest:e2e:extensions": "node extension-sdk/scripts/package-extension.js extension-sdk/example/com.clearpathai.sdk-example --output ./",
    "pw": "npm run build && playwright test",
    "pw:headed": "npm run build && playwright test --headed --workers=1",
    "pw:ui": "npm run build && playwright test --ui",
    "pw:debug": "npm run build && playwright test --debug",
    "pw:screenshots": "npm run build && CLEARPATH_E2E_VISUAL=1 playwright test -c playwright.screenshots.config.ts",
    "pw:screenshots:update": "npm run build && CLEARPATH_E2E_VISUAL=1 playwright test -c playwright.screenshots.config.ts -u",
    "pw:screenshots:experimental": "CLEARPATH_E2E_EXPERIMENTAL=1 npm run build && CLEARPATH_E2E_VISUAL=1 CLEARPATH_E2E_EXPERIMENTAL=1 playwright test -c playwright.screenshots.experimental.config.ts",
    "pw:screenshots:experimental:update": "CLEARPATH_E2E_EXPERIMENTAL=1 npm run build && CLEARPATH_E2E_VISUAL=1 CLEARPATH_E2E_EXPERIMENTAL=1 playwright test -c playwright.screenshots.experimental.config.ts -u",
    "pw:report": "playwright show-report",
    "pw:extensions": "npm run pretest:e2e:extensions && CLEARPATH_E2E_EXPERIMENTAL=1 npm run build && CLEARPATH_E2E_EXPERIMENTAL=1 playwright test -c playwright.extensions.config.ts",
    "typecheck:playwright": "tsc -p tsconfig.playwright.json --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.118",
    "@anthropic-ai/tokenizer": "^0.0.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@uiw/react-codemirror": "^4.25.9",
    "adm-zip": "^0.5.17",
    "archiver": "^7.0.1",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3",
    "jira.js": "^5.3.1",
    "node-cron": "^4.2.1",
    "octokit": "^5.0.5",
    "pull-request-score": "^2.0.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-grid-layout": "^2.2.3",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.26.1",
    "recharts": "^3.8.1",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tiktoken": "^1.0.22"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/adm-zip": "^0.5.8",
    "@types/archiver": "^7.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/react-grid-layout": "^1.3.6",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^4.1.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^39.8.6",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "vite": "^6.3.0",
    "vitest": "^4.1.4",
    "wait-on": "^9.0.5"
  },
  "overrides": {
    "axios": "^1.15.0",
    "serialize-javascript": "^7.0.5"
  },
  "build": {
    "appId": "com.clearpathai.app",
    "productName": "ClearPathAI",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "extensions/",
        "to": "extensions/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "npmRebuild": false,
    "icon": "build/icon",
    "mac": {
      "target": "dmg",
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "category": "Development",
      "icon": "build/icon.png"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    }
  }
}
