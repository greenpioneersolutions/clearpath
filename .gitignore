# Dependencies
node_modules/
.npm
.yarn

# Build output
dist/
dist-electron/
out/
*.tsbuildinfo

# Electron packaging
*.dmg
*.AppImage
*.exe
*.snap

# Environment & secrets
.env
.env.*
*.local

# Local config (contains personal paths)
.claude/settings.local.json

# Per-project Claude memory — path embeds the local username, keep out of Git
.claude/projects/

# App data (user-specific, generated at runtime)
.clear-path/

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Editor / IDE
.idea/
.vscode/
*.swp
*~
*.suo
*.ntvs*
*.njsproj
*.sln

# Logs
*.log
npm-debug.log*
yarn-error.log*

# Testing
coverage/

# Generated E2E screenshots (baseline is committed via Git LFS; these are generated)
e2e/screenshots/actual/
e2e/screenshots/failures/
e2e/screenshots/diff/

# Extension build artifacts
dist-extensions/
*.clear.ext
# Root extension for tests
com.clearpathai.sdk-example-v1.0.0.clear.ext

# The SDK example extension's prebuilt dist/ is committed as a test fixture.
# (The example has no src/ to rebuild from — these files are the canonical
# main + renderer bundles used by e2e/extensions-integration.pw.spec.ts.)
# The blanket `dist/` rule earlier in this file would otherwise ignore them.
!extension-sdk/example/com.clearpathai.sdk-example/dist/
!extension-sdk/example/com.clearpathai.sdk-example/dist/**

# Misc
.cache/
.temp/

# Visual regression — actual + diff images generated during test runs (ephemeral)
.tmp/

# Playwright artifacts
test-results/
test-results-visual/
test-results-visual-experimental/
playwright-report/
blob-report/
e2e/.userData/
.last-run.json
