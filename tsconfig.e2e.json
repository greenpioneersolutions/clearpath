{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ESNext"],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "out/e2e",
    "baseUrl": ".",
    "types": ["@wdio/globals/types", "@wdio/visual-service", "node", "mocha"],
    "skipLibCheck": true
  },
  "include": ["e2e/**/*.ts", "wdio.conf.ts", "wdio.screenshots.conf.ts"],
  "exclude": ["node_modules", "out", "src"]
}
