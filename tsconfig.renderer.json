{
  "compilerOptions": {
    "composite": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "outDir": "out/renderer",
    "rootDir": "src/renderer"
  },
  "include": ["src/renderer/**/*"]
}
