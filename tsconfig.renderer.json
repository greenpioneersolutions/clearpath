{
  "compilerOptions": {
    "composite": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "outDir": "out/renderer",
    // `rootDirs` virtually merges `src/renderer` and `src/shared` so renderer
    // files can import dependency-free type modules from `src/shared/**`.
    "rootDir": "src",
    "rootDirs": ["src/renderer", "src/shared"],
    "types": ["vitest/globals"]
  },
  "include": ["src/renderer/**/*", "src/shared/**/*"]
}
